---
const year = new Date().getFullYear();
---

<footer style="border-top: 1px solid var(--border); margin-top: 5rem;">
  <div style="max-width: 720px; margin: 0 auto; padding: 2rem 1.5rem; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;">
    <span style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--muted-2);">
      © {year} <span style="color: var(--accent);">0xMiikey</span>
    </span>
    <div style="display: flex; gap: 1.5rem; align-items: center;">
      <a href="https://twitter.com/0xmiikey" target="_blank" rel="noopener" class="nav-link" style="font-family: var(--font-mono); font-size: 0.75rem;">Twitter</a>
      <a href="https://github.com/miikey" target="_blank" rel="noopener" class="nav-link" style="font-family: var(--font-mono); font-size: 0.75rem;">GitHub</a>
      <a href="/rss.xml" class="nav-link" style="font-family: var(--font-mono); font-size: 0.75rem;">RSS</a>
    </div>
  </div>
</footer>
