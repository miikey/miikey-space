---
const year = new Date().getFullYear();
---

<footer style="border-top: 1px solid var(--border); margin-top: 4rem;">
  <div style="max-width: 680px; margin: 0 auto; padding: 2rem 1.5rem; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem;">
    <span style="font-size: 0.85rem; color: var(--muted);">© {year} MIIKEY</span>
    <div style="display: flex; gap: 1.25rem;">
      <a href="https://github.com/miikey" target="_blank" rel="noopener" style="font-size: 0.85rem; color: var(--muted); text-decoration: none;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--muted)'">GitHub</a>
      <a href="https://twitter.com/miikey" target="_blank" rel="noopener" style="font-size: 0.85rem; color: var(--muted); text-decoration: none;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--muted)'">X / Twitter</a>
      <a href="/rss.xml" style="font-size: 0.85rem; color: var(--muted); text-decoration: none;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--muted)'">RSS</a>
    </div>
  </div>
</footer>
