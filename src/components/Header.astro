---
import { SITE_TITLE } from '../consts';
---

<header style="border-bottom: 1px solid var(--border); background: var(--bg);">
  <nav style="max-width: 680px; margin: 0 auto; padding: 0 1.5rem; display: flex; align-items: center; justify-content: space-between; height: 56px;">
    <a href="/" style="font-weight: 600; font-size: 1rem; text-decoration: none; letter-spacing: -0.01em;">
      {SITE_TITLE}
    </a>
    <div style="display: flex; gap: 1.5rem; align-items: center;">
      <a href="/blog" style="font-size: 0.9rem; color: var(--muted); text-decoration: none; transition: color 0.15s;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--muted)'">Writing</a>
      <a href="/projects" style="font-size: 0.9rem; color: var(--muted); text-decoration: none; transition: color 0.15s;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--muted)'">Projects</a>
      <a href="/about" style="font-size: 0.9rem; color: var(--muted); text-decoration: none; transition: color 0.15s;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--muted)'">About</a>
    </div>
  </nav>
</header>
