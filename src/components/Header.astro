---
const nav = [
  { href: '/blog', label: 'Writing' },
  { href: '/projects', label: 'Projects' },
  { href: '/about', label: 'About' },
];
const path = Astro.url.pathname;
---

<header style="border-bottom: 1px solid var(--border); position: sticky; top: 0; z-index: 50; backdrop-filter: blur(12px); background: rgba(10,10,10,0.85);">
  <nav style="max-width: 720px; margin: 0 auto; padding: 0 1.5rem; display: flex; align-items: center; justify-content: space-between; height: 52px;">
    <a href="/" style="font-family: var(--font-mono); font-size: 0.9rem; font-weight: 500; color: var(--accent); letter-spacing: -0.01em; text-decoration: none;">
      0xmiikey
    </a>
    <div style="display: flex; gap: 1.75rem; align-items: center;">
      {nav.map(({ href, label }) => (
        <a
          href={href}
          class="nav-link"
          style={path.startsWith(href) ? 'color: var(--fg);' : ''}
        >{label}</a>
      ))}
    </div>
  </nav>
</header>
