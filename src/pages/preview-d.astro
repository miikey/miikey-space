---
import BaseHead from '../components/BaseHead.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead title="Layout D — Magazine Cards" description="Preview" />
  <style>
    .wrap { max-width: 900px; margin: 0 auto; padding: 0 1.5rem 6rem; }
    .hero { padding: 4rem 0 3rem; border-bottom: 1px solid var(--border); margin-bottom: 3rem; display:flex; justify-content:space-between; align-items:flex-end; gap:2rem; flex-wrap:wrap; }
    .cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--border); margin-bottom: 4rem; }
    .card { background: var(--bg); padding: 1.5rem; text-decoration: none; color: var(--fg); transition: background 0.15s; display:flex; flex-direction:column; }
    .card:hover { background: var(--bg-2); }
    .card:hover .c-title { color: var(--accent); }
    .card.featured { grid-column: span 2; }
    .c-title { font-size: 0.95rem; font-weight: 500; line-height: 1.4; margin-bottom: 0.5rem; transition: color 0.15s; }
    .c-desc { font-size: 0.8rem; color: var(--muted); line-height: 1.6; flex: 1; }
    .c-meta { font-family: var(--font-mono); font-size: 0.65rem; color: var(--muted-2); margin-top: 1rem; }
    .p-cards { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--border); }
    .p-card { background: var(--bg); padding: 1.25rem; text-decoration: none; color: var(--fg); transition: background 0.15s; }
    .p-card:hover { background: var(--bg-2); }
    .p-card:hover .p-name { color: var(--accent); }
    .p-name { font-size: 0.9rem; font-weight: 500; margin-bottom: 0.35rem; transition: color 0.15s; }
    .p-desc { font-size: 0.75rem; color: var(--muted); line-height: 1.5; }
    .label { font-family: var(--font-mono); font-size: 0.62rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted-2); margin-bottom: 1px; }
    @media(max-width:700px){ .cards,.p-cards{grid-template-columns:1fr} .card.featured{grid-column:span 1} }
  </style>
</head>
<body>
  <!-- Preview badge -->
  <div style="background:var(--accent-dim);border-bottom:1px solid rgba(0,220,130,0.2);padding:0.6rem 1.5rem;display:flex;align-items:center;justify-content:space-between;">
    <span style="font-family:var(--font-mono);font-size:0.7rem;color:var(--accent);">Preview — Layout D: Magazine Cards</span>
    <div style="display:flex;gap:1.5rem;">
      <a href="/preview-c" style="font-family:var(--font-mono);font-size:0.7rem;color:var(--muted);text-decoration:none;">← Layout C</a>
      <a href="/preview-a" style="font-family:var(--font-mono);font-size:0.7rem;color:var(--muted);text-decoration:none;">Back to A</a>
    </div>
  </div>

  <!-- Nav -->
  <nav style="max-width:900px;margin:0 auto;padding:1.25rem 1.5rem;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--border);">
    <span style="font-family:var(--font-mono);font-size:0.9rem;color:var(--accent);">0xMiikey</span>
    <div style="display:flex;gap:2rem;">
      <a href="#" style="font-size:0.83rem;color:var(--muted);text-decoration:none;">Writing</a>
      <a href="#" style="font-size:0.83rem;color:var(--muted);text-decoration:none;">Projects</a>
      <a href="#" style="font-size:0.83rem;color:var(--muted);text-decoration:none;">About</a>
    </div>
  </nav>

  <div class="wrap">
    <!-- Hero -->
    <div class="hero">
      <div>
        <h1 style="font-size:clamp(1.8rem,4vw,2.5rem);font-weight:700;letter-spacing:-0.03em;line-height:1.2;margin-bottom:0.75rem;">
          0xMiikey
        </h1>
        <p style="font-size:0.95rem;color:var(--muted);max-width:420px;line-height:1.7;">
          Engineer turned founder. Building payment infrastructure for the borderless economy. Writing about fintech, crypto, and AI.
        </p>
      </div>
      <div style="display:flex;flex-direction:column;align-items:flex-end;gap:0.5rem;flex-shrink:0;">
        <span style="font-family:var(--font-mono);font-size:0.72rem;color:var(--accent);background:var(--accent-dim);border:1px solid rgba(0,220,130,0.2);padding:0.25rem 0.7rem;border-radius:999px;">Fintech · Crypto · AI</span>
        <a href="https://twitter.com/0xmiikey" style="font-family:var(--font-mono);font-size:0.72rem;color:var(--muted);text-decoration:none;">@0xmiikey ↗</a>
      </div>
    </div>

    <!-- Writing cards -->
    <p class="label">Writing</p>
    <div class="cards">
      {posts.map((p, i) => (
        <a href={`/blog/${p.id}/`} class={`card ${i === 0 ? 'featured' : ''}`}>
          <div class="c-meta">{p.data.pubDate.toLocaleDateString('en-US', {year:'numeric',month:'short'})}</div>
          <div class="c-title" style={i === 0 ? 'font-size:1.1rem;margin-top:0.4rem' : 'margin-top:0.4rem'}>{p.data.title}</div>
          <div class="c-desc">{p.data.description}</div>
        </a>
      ))}
    </div>

    <!-- Projects cards -->
    <p class="label">Projects</p>
    <div class="p-cards">
      {[
        {
        {name:'ClearChain', desc:'Blockchain settlement layer — T+2 to real-time.', tag:'Protocol', status:'Building', href:'/projects/clearchain'},
        {name:'RiskGuard', desc:'AI fraud detection for card acquiring pipelines.', tag:'AI · Risk', status:'Building', href:'/projects/riskguard'},
        {name:'Threshold Signer', desc:'MPC wallet infrastructure for institutional custody.', tag:'MPC', status:'Building', href:'/projects/threshold-signer'},
      ].map(p => (
        <a href={p.href} class="p-card">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:0.5rem;">
            <span class="tag" style="font-size:0.6rem">{p.tag}</span>
            <span style={`font-size:0.6rem;font-family:var(--font-mono);padding:0.1rem 0.45rem;border-radius:999px;${p.status==='Live'?'color:var(--accent);background:var(--accent-dim);border:1px solid rgba(0,220,130,0.2)':'color:var(--muted);background:var(--bg-2);border:1px solid var(--border)'}`}>{p.status}</span>
          </div>
          <div class="p-name">{p.name}</div>
          <div class="p-desc">{p.desc}</div>
        </a>
      ))}
    </div>
  </div>
</body>
</html>
