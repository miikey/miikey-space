---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead title="Layout A — Dual Column" description="Preview" />
  <style>
    .layout { display: grid; grid-template-columns: 220px 1fr; min-height: 100vh; }
    .sidebar { position: sticky; top: 0; height: 100vh; border-right: 1px solid var(--border); padding: 2.5rem 1.75rem; display: flex; flex-direction: column; }
    .main { padding: 3rem 3rem 5rem; max-width: 620px; }
    .nav-item { font-size: 0.82rem; color: var(--muted); text-decoration: none; display: block; padding: 0.35rem 0; transition: color 0.15s; }
    .nav-item:hover { color: var(--fg); }
    .section-label { font-family: var(--font-mono); font-size: 0.62rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted-2); margin-bottom: 1rem; margin-top: 2.5rem; }
    .row { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; padding: 0.75rem 0; border-top: 1px solid var(--border); text-decoration: none; color: var(--fg); }
    .row:hover .row-t { color: var(--accent); }
    .row-t { font-size: 0.92rem; transition: color 0.15s; }
    .row-d { font-size: 0.75rem; color: var(--muted); white-space: nowrap; font-family: var(--font-mono); }
    @media(max-width:700px){ .layout{grid-template-columns:1fr} .sidebar{position:static;height:auto;border-right:none;border-bottom:1px solid var(--border)} }
  </style>
</head>
<body>
  <!-- Preview badge -->
  <div style="background: var(--accent-dim); border-bottom: 1px solid rgba(0,220,130,0.2); padding: 0.6rem 1.5rem; display:flex; align-items:center; justify-content:space-between;">
    <span style="font-family:var(--font-mono);font-size:0.7rem;color:var(--accent);">Preview — Layout A: Dual Column</span>
    <a href="/preview-b" style="font-family:var(--font-mono);font-size:0.7rem;color:var(--muted);text-decoration:none;">Next: Layout B →</a>
  </div>

  <div class="layout">
    <!-- Sidebar -->
    <aside class="sidebar">
      <div style="margin-bottom:auto">
        <a href="/" style="font-family:var(--font-mono);font-size:0.9rem;color:var(--accent);text-decoration:none;display:block;margin-bottom:2rem;">0xMiikey</a>
        <p style="font-size:0.82rem;color:var(--muted);line-height:1.7;margin-bottom:1.5rem;">Engineer turned founder. Co-building payment infrastructure at the intersection of fintech, crypto & AI.</p>
        <nav>
          <a href="#" class="nav-item">Writing</a>
          <a href="#" class="nav-item">Projects</a>
          <a href="#" class="nav-item">About</a>
        </nav>
      </div>
      <div style="margin-top:2rem">
        <a href="https://twitter.com/0xmiikey" style="font-family:var(--font-mono);font-size:0.7rem;color:var(--muted);text-decoration:none;display:block;margin-bottom:0.4rem;">@0xmiikey ↗</a>
        <a href="https://github.com/miikey" style="font-family:var(--font-mono);font-size:0.7rem;color:var(--muted);text-decoration:none;display:block;">github/miikey ↗</a>
      </div>
    </aside>

    <!-- Main -->
    <main class="main">
      <div class="section-label">Writing</div>
      <ul style="list-style:none;">
        {posts.map(p => (
          <li>
            <a href={`/blog/${p.id}/`} class="row">
              <span class="row-t">{p.data.title}</span>
              <span class="row-d">{p.data.pubDate.getFullYear()}</span>
            </a>
          </li>
        ))}
        <li style="border-top:1px solid var(--border)"></li>
      </ul>

      <div class="section-label">Projects</div>
      <ul style="list-style:none;">
        {[
          {
          {name:'ClearChain', desc:'Blockchain settlement layer for cross-border networks.', tag:'Protocol', href:'/projects/clearchain'},
          {name:'RiskGuard', desc:'AI fraud detection for card acquiring pipelines.', tag:'AI · Risk', href:'/projects/riskguard'},
          {name:'Threshold Signer', desc:'MPC wallet infrastructure for institutional key management.', tag:'MPC', href:'/projects/threshold-signer'},
        ].map(p => (
          <li>
            <a href={p.href} class="row" style="align-items:center;">
              <div>
                <div class="row-t">{p.name}</div>
                <div style="font-size:0.78rem;color:var(--muted);margin-top:0.15rem;">{p.desc}</div>
              </div>
              <span class="tag">{p.tag}</span>
            </a>
          </li>
        ))}
        <li style="border-top:1px solid var(--border)"></li>
      </ul>
    </main>
  </div>
</body>
</html>
