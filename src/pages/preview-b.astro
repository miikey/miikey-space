---
import BaseHead from '../components/BaseHead.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead title="Layout B — Big Hero" description="Preview" />
  <style>
    .hero { padding: 6rem 2rem 5rem; max-width: 860px; margin: 0 auto; }
    .content { max-width: 860px; margin: 0 auto; padding: 0 2rem 6rem; }
    .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--border); margin-bottom: 4rem; }
    .grid-item { background: var(--bg); padding: 1.75rem; text-decoration: none; color: var(--fg); transition: background 0.15s; }
    .grid-item:hover { background: var(--bg-2); }
    .grid-item:hover .gi-title { color: var(--accent); }
    .gi-title { font-size: 1rem; font-weight: 500; margin-bottom: 0.4rem; transition: color 0.15s; }
    .gi-desc { font-size: 0.82rem; color: var(--muted); line-height: 1.6; }
    .gi-meta { font-family: var(--font-mono); font-size: 0.68rem; color: var(--muted-2); margin-top: 0.75rem; }
    @media(max-width:600px){ .grid{grid-template-columns:1fr} }
  </style>
</head>
<body>
  <!-- Preview badge -->
  <div style="background: var(--accent-dim); border-bottom: 1px solid rgba(0,220,130,0.2); padding: 0.6rem 1.5rem; display:flex; align-items:center; justify-content:space-between;">
    <span style="font-family:var(--font-mono);font-size:0.7rem;color:var(--accent);">Preview — Layout B: Big Hero</span>
    <div style="display:flex;gap:1.5rem;">
      <a href="/preview-a" style="font-family:var(--font-mono);font-size:0.7rem;color:var(--muted);text-decoration:none;">← Layout A</a>
      <a href="/preview-c" style="font-family:var(--font-mono);font-size:0.7rem;color:var(--muted);text-decoration:none;">Layout C →</a>
    </div>
  </div>

  <!-- Nav -->
  <nav style="max-width:860px;margin:0 auto;padding:1.5rem 2rem;display:flex;justify-content:space-between;align-items:center;">
    <span style="font-family:var(--font-mono);font-size:0.9rem;color:var(--accent);">0xMiikey</span>
    <div style="display:flex;gap:2rem;">
      <a href="#" style="font-size:0.85rem;color:var(--muted);text-decoration:none;">Writing</a>
      <a href="#" style="font-size:0.85rem;color:var(--muted);text-decoration:none;">Projects</a>
      <a href="#" style="font-size:0.85rem;color:var(--muted);text-decoration:none;">About</a>
    </div>
  </nav>

  <!-- Hero -->
  <div class="hero">
    <div style="font-family:var(--font-mono);font-size:0.75rem;color:var(--accent);background:var(--accent-dim);border:1px solid rgba(0,220,130,0.2);padding:0.3rem 0.8rem;border-radius:999px;display:inline-block;margin-bottom:2rem;">
      Co-founder & CTO · UQPAY
    </div>
    <h1 style="font-size:clamp(3rem,7vw,5rem);font-weight:700;letter-spacing:-0.04em;line-height:1.05;margin-bottom:2rem;color:var(--fg);">
      Building at the<br/>edge of <span style="color:var(--accent)">fintech,<br/>crypto & AI.</span>
    </h1>
    <p style="font-size:1.1rem;color:#777;line-height:1.8;max-width:540px;">
      Engineer turned founder. Co-building UQPAY — payment infrastructure for the borderless economy. Obsessed with the intersection of crypto-native rails and real-world money movement.
    </p>
    <div style="display:flex;gap:1.5rem;margin-top:2.5rem;">
      <a href="#" style="font-family:var(--font-mono);font-size:0.82rem;color:var(--muted);text-decoration:none;">@0xmiikey ↗</a>
      <a href="#" style="font-family:var(--font-mono);font-size:0.82rem;color:var(--muted);text-decoration:none;">github ↗</a>
    </div>
  </div>

  <div class="content">
    <!-- Writing grid -->
    <p style="font-family:var(--font-mono);font-size:0.65rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted-2);margin-bottom:1px;">Writing</p>
    <div class="grid">
      {posts.map(p => (
        <a href={`/blog/${p.id}/`} class="grid-item">
          <div class="gi-title">{p.data.title}</div>
          <div class="gi-desc">{p.data.description}</div>
          <div class="gi-meta">{p.data.pubDate.toLocaleDateString('en-US', {year:'numeric',month:'short'})}</div>
        </a>
      ))}
    </div>

    <!-- Projects grid -->
    <p style="font-family:var(--font-mono);font-size:0.65rem;text-transform:uppercase;letter-spacing:0.1em;color:var(--muted-2);margin-bottom:1px;">Projects</p>
    <div class="grid">
      {[
        {name:'UQPAY', desc:'Global payment infrastructure for the borderless economy.', tag:'Fintech', href:'/projects/uqpay'},
        {name:'ClearChain', desc:'Blockchain settlement layer — T+2 to real-time.', tag:'Protocol', href:'/projects/clearchain'},
        {name:'RiskGuard', desc:'AI fraud detection for card acquiring.', tag:'AI · Risk', href:'/projects/riskguard'},
        {name:'Threshold Signer', desc:'MPC wallet infrastructure for institutional custody.', tag:'MPC', href:'/projects/threshold-signer'},
      ].map(p => (
        <a href={p.href} class="grid-item">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:0.5rem;">
            <div class="gi-title" style="margin:0">{p.name}</div>
            <span class="tag" style="margin-left:0.5rem;flex-shrink:0">{p.tag}</span>
          </div>
          <div class="gi-desc">{p.desc}</div>
        </a>
      ))}
    </div>
  </div>
</body>
</html>
