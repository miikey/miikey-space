---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
---

<!doctype html>
<html lang="en">
<head>
  <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  <style>
    .wrap { max-width: 900px; margin: 0 auto; padding: 0 1.5rem 6rem; }
    .hero { padding: 4rem 0 3rem; border-bottom: 1px solid var(--border); margin-bottom: 3rem; display: flex; justify-content: space-between; align-items: flex-end; gap: 2rem; flex-wrap: wrap; }
    .section-label { font-family: var(--font-mono); font-size: 0.62rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted-2); margin-bottom: 1px; }
    .cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--border); margin-bottom: 4rem; }
    .card { background: var(--bg); text-decoration: none; color: var(--fg); transition: background 0.15s; display: flex; flex-direction: column; overflow: hidden; }
    .card:hover { background: var(--bg-2); }
    .card:hover .c-title { color: var(--accent); }
    .card.featured { grid-column: span 2; }
    .card-img { width: 100%; height: 160px; object-fit: cover; display: block; border-bottom: 1px solid var(--border); }
    .card.featured .card-img { height: 200px; }
    .card-body { padding: 1.25rem; flex: 1; display: flex; flex-direction: column; }
    .c-meta { font-family: var(--font-mono); font-size: 0.65rem; color: var(--muted-2); margin-bottom: 0.5rem; }
    .c-title { font-size: 0.95rem; font-weight: 500; line-height: 1.4; margin-bottom: 0.5rem; transition: color 0.15s; }
    .c-desc { font-size: 0.8rem; color: var(--muted); line-height: 1.6; flex: 1; }
    .p-cards { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: var(--border); }
    .p-card { background: var(--bg); padding: 1.25rem; text-decoration: none; color: var(--fg); transition: background 0.15s; }
    .p-card:hover { background: var(--bg-2); }
    .p-card:hover .p-name { color: var(--accent); }
    .p-name { font-size: 0.9rem; font-weight: 500; margin-bottom: 0.35rem; transition: color 0.15s; }
    .p-desc { font-size: 0.75rem; color: var(--muted); line-height: 1.5; }
    @media(max-width: 700px) {
      .cards, .p-cards { grid-template-columns: 1fr; }
      .card.featured { grid-column: span 1; }
      .hero { flex-direction: column; align-items: flex-start; }
    }
  </style>
</head>
<body>
  <!-- Nav -->
  <nav style="max-width:900px;margin:0 auto;padding:1.25rem 1.5rem;display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--border);">
    <a href="/" style="font-family:var(--font-mono);font-size:0.9rem;color:var(--accent);text-decoration:none;">0xMiikey</a>
    <div style="display:flex;gap:2rem;align-items:center;">
      <a href="/blog" style="font-size:0.83rem;color:var(--muted);text-decoration:none;transition:color 0.15s;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--muted)'">Writing</a>
      <a href="/projects" style="font-size:0.83rem;color:var(--muted);text-decoration:none;transition:color 0.15s;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--muted)'">Projects</a>
      <a href="/about" style="font-size:0.83rem;color:var(--muted);text-decoration:none;transition:color 0.15s;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--muted)'">About</a>
      <button id="theme-toggle-home" aria-label="Toggle theme" style="background:none;border:none;cursor:pointer;color:var(--muted);padding:4px;display:flex;align-items:center;transition:color 0.15s;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--muted)'">
        <svg id="home-icon-sun" xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none">
          <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
          <line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
        </svg>
        <svg id="home-icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
      </button>
    </div>
  </nav>

  <script>
    (function() {
      var stored = localStorage.getItem('theme');
      var theme = stored === 'light' || stored === 'dark'
        ? stored
        : (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark');
      var sun = document.getElementById('home-icon-sun');
      var moon = document.getElementById('home-icon-moon');
      if (sun && moon) {
        sun.style.display = theme === 'light' ? 'block' : 'none';
        moon.style.display = theme === 'light' ? 'none' : 'block';
      }
      document.getElementById('theme-toggle-home')?.addEventListener('click', function() {
        var current = document.documentElement.getAttribute('data-theme') === 'light' ? 'light' : 'dark';
        var next = current === 'dark' ? 'light' : 'dark';
        localStorage.setItem('theme', next);
        document.documentElement.setAttribute('data-theme', next === 'light' ? 'light' : '');
        var s = document.getElementById('home-icon-sun');
        var m = document.getElementById('home-icon-moon');
        if (s && m) { s.style.display = next === 'light' ? 'block' : 'none'; m.style.display = next === 'light' ? 'none' : 'block'; }
      });
    })();
  </script>

  <div class="wrap">
    <!-- Hero -->
    <div class="hero">
      <div>
        <h1 style="font-size:clamp(2rem,5vw,2.75rem);font-weight:700;letter-spacing:-0.04em;line-height:1.15;margin-bottom:0.75rem;color:var(--fg);">
          0xMiikey
        </h1>
        <p style="font-size:0.98rem;color:var(--muted);max-width:440px;line-height:1.8;">
          Engineer turned founder. Building payment infrastructure for the borderless economy.
          Writing about fintech, crypto & AI.
        </p>
      </div>
      <div style="display:flex;flex-direction:column;align-items:flex-end;gap:0.6rem;flex-shrink:0;">
        <span style="font-family:var(--font-mono);font-size:0.72rem;color:var(--accent);background:var(--accent-dim);border:1px solid var(--accent-dim);padding:0.25rem 0.7rem;border-radius:999px;">
          Fintech · Crypto · AI
        </span>
        <div style="display:flex;gap:1.25rem;">
          <a href="https://twitter.com/0xmiikey" target="_blank" rel="noopener" style="font-family:var(--font-mono);font-size:0.72rem;color:var(--muted);text-decoration:none;transition:color 0.15s;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--muted)'">@0xmiikey ↗</a>
          <a href="https://github.com/miikey" target="_blank" rel="noopener" style="font-family:var(--font-mono);font-size:0.72rem;color:var(--muted);text-decoration:none;transition:color 0.15s;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--muted)'">github ↗</a>
        </div>
      </div>
    </div>

    <!-- Writing -->
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1px;">
      <p class="section-label" style="margin:0">Writing</p>
      <a href="/blog" style="font-family:var(--font-mono);font-size:0.68rem;color:var(--muted);text-decoration:none;transition:color 0.15s;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--muted)'">All posts →</a>
    </div>
    <div class="cards">
      {posts.map((p, i) => (
        <a href={`/blog/${p.id}/`} class={`card${i === 0 ? ' featured' : ''}`}>
          {p.data.heroImage && (
            <img src={p.data.heroImage} alt={p.data.heroAlt ?? p.data.title} class="card-img" loading="lazy" />
          )}
          <div class="card-body">
            <div class="c-meta">{p.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}</div>
            <div class="c-title" style={i === 0 ? 'font-size:1.05rem' : ''}>{p.data.title}</div>
            <div class="c-desc">{p.data.description}</div>
          </div>
        </a>
      ))}
    </div>

    <!-- Projects -->
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1px;">
      <p class="section-label" style="margin:0">Projects</p>
      <a href="/projects" style="font-family:var(--font-mono);font-size:0.68rem;color:var(--muted);text-decoration:none;transition:color 0.15s;" onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--muted)'">All projects →</a>
    </div>
    <div class="p-cards">
      {[
        { name: 'ClearChain', desc: 'Blockchain settlement layer — T+2 to real-time.', tag: 'Protocol', status: 'Building', href: '/projects/clearchain' },
        { name: 'RiskGuard', desc: 'AI fraud detection for card acquiring pipelines.', tag: 'AI · Risk', status: 'Building', href: '/projects/riskguard' },
        { name: 'Threshold Signer', desc: 'MPC wallet infrastructure for institutional custody.', tag: 'MPC', status: 'Building', href: '/projects/threshold-signer' },
        { name: 'CardOS', desc: 'Programmable card issuance platform via API.', tag: 'Issuing', status: 'Building', href: '/projects/cardos' },
      ].map((p) => (
        <a href={p.href} class="p-card">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:0.6rem;">
            <span class="tag" style="font-size:0.6rem">{p.tag}</span>
            <span style={`font-size:0.6rem;font-family:var(--font-mono);padding:0.1rem 0.45rem;border-radius:999px;${p.status === 'Live' ? 'color:var(--accent);background:var(--accent-dim);border:1px solid var(--accent-dim)' : 'color:var(--muted-2);background:var(--bg-2);border:1px solid var(--border)'}`}>{p.status}</span>
          </div>
          <div class="p-name">{p.name}</div>
          <div class="p-desc">{p.desc}</div>
        </a>
      ))}
    </div>
  </div>

  <Footer />
</body>
</html>
