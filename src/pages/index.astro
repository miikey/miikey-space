---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 5);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main style="max-width: 680px; margin: 0 auto; padding: 3rem 1.5rem;">

      <!-- Hero -->
      <section style="margin-bottom: 4rem;">
        <h1 style="font-size: 1.5rem; font-weight: 600; letter-spacing: -0.02em; margin-bottom: 1rem; line-height: 1.3;">
          MIIKEY
        </h1>
        <p style="font-size: 1.05rem; color: var(--muted); line-height: 1.8; max-width: 520px;">
          Builder, thinker, crypto enthusiast. Interested in DeFi, product, and the open web.
          Writing about things I'm building and learning.
        </p>
        <div style="display: flex; gap: 1rem; margin-top: 1.5rem; flex-wrap: wrap;">
          <a href="https://github.com/miikey" target="_blank" rel="noopener"
            style="font-size: 0.875rem; color: var(--muted); text-decoration: none; display: flex; align-items: center; gap: 0.35rem;"
            onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--muted)'">
            GitHub ↗
          </a>
          <a href="https://twitter.com/miikey" target="_blank" rel="noopener"
            style="font-size: 0.875rem; color: var(--muted); text-decoration: none;"
            onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--muted)'">
            X / Twitter ↗
          </a>
        </div>
      </section>

      <!-- Writing -->
      <section style="margin-bottom: 4rem;">
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.25rem;">
          <h2 style="font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted);">
            Writing
          </h2>
          <a href="/blog" style="font-size: 0.85rem; color: var(--muted); text-decoration: none;"
            onmouseover="this.style.color='var(--fg)'" onmouseout="this.style.color='var(--muted)'">
            All posts →
          </a>
        </div>
        <ul style="list-style: none; display: flex; flex-direction: column; gap: 0;">
          {posts.map((post) => (
            <li style="border-top: 1px solid var(--border);">
              <a href={`/blog/${post.id}/`}
                style="display: flex; align-items: baseline; justify-content: space-between; padding: 0.85rem 0; text-decoration: none; gap: 1rem;"
                onmouseover="this.querySelector('.post-title').style.color='var(--muted)'"
                onmouseout="this.querySelector('.post-title').style.color='var(--fg)'">
                <span class="post-title" style="font-size: 0.95rem; color: var(--fg); transition: color 0.15s; flex: 1; min-width: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                  {post.data.title}
                </span>
                <span style="font-size: 0.8rem; color: var(--muted); white-space: nowrap; font-variant-numeric: tabular-nums;">
                  <FormattedDate date={post.data.pubDate} />
                </span>
              </a>
            </li>
          ))}
          <li style="border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);"></li>
        </ul>
      </section>

      <!-- Projects -->
      <section style="margin-bottom: 4rem;">
        <h2 style="font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); margin-bottom: 1.25rem;">
          Projects
        </h2>
        <ul style="list-style: none; display: flex; flex-direction: column; gap: 0;">
          {[
            {
              name: 'miikey-space',
              desc: 'Personal site and writing. Built with Astro.',
              href: 'https://github.com/miikey/miikey-space',
            },
            {
              name: 'defistation-web',
              desc: 'DeFi analytics and tracking dashboard.',
              href: 'https://github.com/miikey/defistation-web',
            },
            {
              name: 'aave-ui',
              desc: 'Interface work for Aave protocol.',
              href: 'https://github.com/miikey/aave-ui',
            },
          ].map((project) => (
            <li style="border-top: 1px solid var(--border);">
              <a href={project.href} target="_blank" rel="noopener"
                style="display: flex; align-items: baseline; justify-content: space-between; padding: 0.85rem 0; text-decoration: none; gap: 1rem; flex-wrap: wrap;">
                <span style="font-size: 0.95rem; color: var(--fg); font-weight: 500;">{project.name}</span>
                <span style="font-size: 0.85rem; color: var(--muted); flex: 1; text-align: right;">{project.desc}</span>
              </a>
            </li>
          ))}
          <li style="border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);"></li>
        </ul>
      </section>

      <!-- Now -->
      <section>
        <h2 style="font-size: 0.8rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.08em; color: var(--muted); margin-bottom: 1rem;">
          Now
        </h2>
        <p style="font-size: 0.95rem; color: var(--muted); line-height: 1.8;">
          Currently exploring DeFi infrastructure, reading about tokenization, and building in public.
          Based in Asia. Open to interesting conversations.
        </p>
      </section>

    </main>
    <Footer />
  </body>
</html>
